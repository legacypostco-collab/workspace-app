DEBUG_MODE=False
SECRET_KEY=change-me-super-secret

ALLOWED_HOSTS=yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

USE_HTTPS=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

BEHIND_PROXY=1
SERVE_MEDIA=0

DB_ENGINE=django.db.backends.postgresql
DB_NAME=marketplace
DB_USER=marketplace
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=5

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Email / SMTP (leave EMAIL_HOST empty to disable verification and use console backend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=Consolidator Parts <noreply@yourdomain.com>

# Payment gateway
PAYMENT_PROVIDER_URL=https://your-payment-provider.com/pay
PAYMENT_MERCHANT_ID=change-me
PAYMENT_CALLBACK_SECRET=change-me

WEBHOOK_SECRET=change-me

LOG_LEVEL=INFO
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=60
CELERY_LOG_LEVEL=INFO
